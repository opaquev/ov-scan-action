# yamllint config for ov-scan-action
extends: default

rules:
  line-length: disable
  document-start: disable
  truthy:
    check-keys: false
  # Allow column-aligned key:value declarations (action.yml env: block).
  # The alignment makes long INPUT_* env-binding tables much more readable
  # for human review of the workflow-injection-prevention pattern (TH7 / R2-M4).
  colons: disable
